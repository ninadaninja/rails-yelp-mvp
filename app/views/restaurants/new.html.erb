<h1>Add a new restaurant</h1>

<%= simple_form_for @restaurant do |f| %>
  <%= f.input :name %>
  <%= f.input :address %>
  <%= f.input :category, collection: Restaurant::CATEGORIES %>

<div class="d-flex mx-3 py-2 gap-3">
<%= link_to "Go back to list of restaurants", restaurants_path, class: "btn btn-secondary"  %>
  <%= f.submit "Create Restaurant", class: "btn btn-primary" %>
<% end %>

</div>
