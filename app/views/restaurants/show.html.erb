<h1><%= @restaurant.name %></h1>

<p><%= @restaurant.address %></p>
<p><%= @restaurant.category.capitalize %></p>

<p><strong>Reviews</strong></p>
<ul class="list-group">
  <% @restaurant.reviews.each do |review| %>
    <li class="list-group-item"><%= review.content %></li>
  <% end %>
</ul>
<br>

<%= link_to "Write a review for this restaurant", new_restaurant_review_path(@restaurant), class: "btn btn-success" %>
<%= link_to "Go back to list of restaurants", restaurants_path, class: "btn btn-primary"  %>
